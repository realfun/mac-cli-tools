#!/usr/bin/env python3
"""secrets - macOS Keychain credential manager.

Store API keys in macOS Keychain under service 'ohmysecrets'.

Usage:
    secrets                        # interactive TUI
    secrets get KEY_NAME           # print a secret value
    secrets list                   # list all managed secret names
    secrets delete KEY_NAME        # remove a secret
    secrets env                    # output "export KEY=val" lines
    secrets init                   # print zshrc snippet
"""

import curses
import re
import subprocess
import sys

SERVICE = "ohmysecrets"


def _security(*args, input_data=None):
    """Run a macOS security command, return (stdout, stderr, returncode)."""
    cmd = ["security"] + list(args)
    proc = subprocess.run(cmd, capture_output=True, text=True, input=input_data)
    return proc.stdout, proc.stderr, proc.returncode


def set_secret(key, value):
    """Store or update a secret in Keychain."""
    # Try updating first, then adding
    _, _, rc = _security(
        "add-generic-password",
        "-s", SERVICE, "-a", key, "-w", value, "-U",
    )
    if rc != 0:
        print(f"Error: failed to set '{key}'", file=sys.stderr)
        sys.exit(1)


def get_secret(key):
    """Retrieve a secret from Keychain. Returns None if not found."""
    stdout, _, rc = _security(
        "find-generic-password",
        "-s", SERVICE, "-a", key, "-w",
    )
    if rc != 0:
        return None
    return stdout.strip()


def delete_secret(key):
    """Delete a secret from Keychain."""
    _, _, rc = _security(
        "delete-generic-password",
        "-s", SERVICE, "-a", key,
    )
    return rc == 0


def _extract_blob(line):
    """Extract the string value from a keychain dump attribute line."""
    # Matches: ="value" or =0xHEX  "value"
    m = re.search(r'=\s*"(.*?)"', line) or re.search(r'=\s*0x[0-9A-Fa-f]+\s+"(.*?)"', line)
    return m.group(1) if m else None


def list_secrets():
    """List all secret names under our service."""
    stdout, stderr, _ = _security("dump-keychain")
    output = stdout + stderr

    # Split into per-entry blocks (each starts with "class:")
    names = []
    for block in re.split(r'(?=^class:)', output, flags=re.MULTILINE):
        svce = None
        acct = None
        for line in block.splitlines():
            stripped = line.strip()
            if '"svce"<blob>' in stripped or "'svce'<blob>" in stripped:
                svce = _extract_blob(stripped)
            elif '"acct"<blob>' in stripped or "'acct'<blob>" in stripped:
                acct = _extract_blob(stripped)
        if svce == SERVICE and acct and acct not in names:
            names.append(acct)
    return sorted(names)


def cmd_get(args):
    if len(args) < 1:
        print("Usage: secrets get KEY_NAME", file=sys.stderr)
        sys.exit(1)
    val = get_secret(args[0])
    if val is None:
        print(f"Error: '{args[0]}' not found", file=sys.stderr)
        sys.exit(1)
    print(val)


def cmd_delete(args):
    if len(args) < 1:
        print("Usage: secrets delete KEY_NAME", file=sys.stderr)
        sys.exit(1)
    if delete_secret(args[0]):
        print(f"Deleted '{args[0]}'")
    else:
        print(f"Error: '{args[0]}' not found", file=sys.stderr)
        sys.exit(1)


def cmd_list(_args):
    for name in list_secrets():
        print(name)


def cmd_env(args):
    names = args if args else list_secrets()
    for name in names:
        val = get_secret(name)
        if val is not None:
            escaped = val.replace("'", "'\\''")
            print(f"export {name}='{escaped}'")
        elif args:
            print(f"Error: '{name}' not found", file=sys.stderr)
            sys.exit(1)


def cmd_init(_args):
    print('# Add this to your ~/.zshrc:')
    print('eval "$(secrets env)"')


# ── TUI ──────────────────────────────────────────────────────────────

def _curses_input(stdscr, row, col, prompt, attr=0):
    """Read a string from the user. Returns None on Escape."""
    curses.curs_set(1)
    stdscr.addstr(row, col, prompt, attr)
    stdscr.clrtoeol()
    stdscr.refresh()
    buf = []
    x = col + len(prompt)
    while True:
        ch = stdscr.getch()
        if ch == 27:  # Escape
            curses.curs_set(0)
            return None
        elif ch in (10, 13, curses.KEY_ENTER):  # Enter
            break
        elif ch == 21:  # Ctrl+U — clear line
            buf.clear()
            x = col + len(prompt)
            stdscr.move(row, x)
            stdscr.clrtoeol()
        elif ch in (curses.KEY_BACKSPACE, 127, 8):
            if buf:
                buf.pop()
                x -= 1
                stdscr.move(row, x)
                stdscr.delch()
        elif 32 <= ch <= 126:
            buf.append(chr(ch))
            stdscr.addch(row, x, ch)
            x += 1
    curses.curs_set(0)
    return "".join(buf).strip()


def _draw(stdscr, names, selected, message=""):
    stdscr.clear()
    h, w = stdscr.getmaxyx()

    title = " secrets — macOS Keychain manager "
    stdscr.addstr(0, max(0, (w - len(title)) // 2), title, curses.A_BOLD)

    help_text = " a:add  e/Enter:edit  d:delete  q:quit "
    stdscr.addstr(1, max(0, (w - len(help_text)) // 2), help_text, curses.A_DIM)

    if not names:
        stdscr.addstr(3, 2, "(no secrets stored)", curses.A_DIM)
    else:
        max_visible = h - 5
        start = max(0, selected - max_visible + 1)
        for i, name in enumerate(names[start:start + max_visible]):
            idx = start + i
            row = 3 + i
            if row >= h - 2:
                break
            marker = " > " if idx == selected else "   "
            attr = curses.A_REVERSE if idx == selected else 0
            text = f"{marker}{name}"
            stdscr.addstr(row, 1, text[:w - 2], attr)

    if message:
        stdscr.addstr(h - 1, 1, message[:w - 2], curses.A_BOLD)

    stdscr.refresh()


def tui(stdscr):
    curses.set_escdelay(25)
    curses.curs_set(0)
    stdscr.keypad(True)
    curses.start_color()
    curses.init_pair(1, curses.COLOR_WHITE, curses.COLOR_RED)
    warn_attr = curses.color_pair(1) | curses.A_BOLD

    names = list_secrets()
    selected = 0
    message = ""

    while True:
        if selected >= len(names):
            selected = max(0, len(names) - 1)
        _draw(stdscr, names, selected, message)
        message = ""

        ch = stdscr.getch()

        if ch == ord("q"):
            break
        elif ch == curses.KEY_UP or ch == ord("k"):
            selected = max(0, selected - 1)
        elif ch == curses.KEY_DOWN or ch == ord("j"):
            selected = min(len(names) - 1, selected + 1) if names else 0
        elif ch == ord("a"):
            h, _ = stdscr.getmaxyx()
            key = _curses_input(stdscr, h - 2, 1, "Key: ")
            if not key:
                message = "Cancelled"
            else:
                val = _curses_input(stdscr, h - 1, 1, "Value: ")
                if not val:
                    message = "Cancelled"
                else:
                    set_secret(key, val)
                    names = list_secrets()
                    try:
                        selected = names.index(key)
                    except ValueError:
                        pass
                    message = f"Added '{key}'"
        elif (ch == ord("e") or ch == 10 or ch == curses.KEY_ENTER) and names:
            key = names[selected]
            current = get_secret(key) or ""
            h, _ = stdscr.getmaxyx()
            stdscr.addstr(h - 3, 1, "(Escape to cancel)", curses.A_DIM)
            stdscr.clrtoeol()
            stdscr.addstr(h - 2, 1, f"Editing '{key}' (current: {current})")
            stdscr.clrtoeol()
            val = _curses_input(stdscr, h - 1, 1, "New value: ", warn_attr)
            if not val:
                message = "Cancelled"
            else:
                set_secret(key, val)
                message = f"Updated '{key}'"
        elif ch == ord("d") and names:
            key = names[selected]
            h, _ = stdscr.getmaxyx()
            confirm = _curses_input(stdscr, h - 1, 1, f"Delete '{key}'? (y/N): ", warn_attr)
            if confirm is not None and confirm.lower() == "y":
                delete_secret(key)
                names = list_secrets()
                message = f"Deleted '{key}'"
            else:
                message = "Cancelled"


def main():
    args = sys.argv[1:]

    if not args:
        curses.wrapper(tui)
        return

    commands = {
        "get": cmd_get,
        "delete": cmd_delete,
        "list": cmd_list,
        "env": cmd_env,
        "init": cmd_init,
    }

    cmd = args[0]
    if cmd in commands:
        commands[cmd](args[1:])
    else:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        print(__doc__.strip(), file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
